{
  "name": "topos",
  "version": "0.1.0",
  "description": "Topos — CLI that visualizes cross-file import graphs for TypeScript/React/Vue/Svelte projects as a self-contained interactive HTML graph.",
  "type": "module",
  "bin": {
    "topos": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "example": "node dist/cli.js example/sample -o example/graph.html"
  },
  "dependencies": {
    "@vue/compiler-sfc": "^3.4.0",
    "commander": "^12.0.0",
    "cytoscape": "^3.34.0",
    "cytoscape-elk": "^2.3.0",
    "cytoscape-fcose": "^2.2.0",
    "elkjs": "^0.11.1",
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.1",
    "svelte": "^4.2.0",
    "ts-morph": "^22.0.0"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.0",
    "@types/node": "^20.12.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
